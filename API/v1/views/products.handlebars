<div class="container mt-4">
  <div class="row">
    {{#each data}}
      <div class="col-lg-3 col-md-4 col-sm-6 p-3">
        <div class="card h-100">
          <img src="/uploads/img/{{picName}}" class="card-img-top product-img" alt="{{pName}}">
          <div class="card-body">
            <h5 class="card-title">{{pName}}</h5>
            <p class="card-text">{{pDesc}}</p>
            <a href="#" class="btn btn-primary" onclick="addToCart({{PID}}, 1)">
              הוסף לסל
            </a>
          </div>
        </div>
      </div>
    {{/each}}
  </div>
</div>